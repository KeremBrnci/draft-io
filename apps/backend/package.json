{
  "name": "@draft-io/backend",
  "version": "0.1.0",
  "private": true,
  "description": "draft.io NestJS backend API",
  "scripts": {
    "build": "nest build",
    "dev": "nest start --watch",
    "start": "node dist/main.js",
    "start:prod": "node dist/main.js",
    "lint": "eslint \"{src,test}/**/*.ts\"",
    "lint:fix": "eslint \"{src,test}/**/*.ts\" --fix",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --config vitest.unit.config.ts && vitest run --config vitest.e2e.config.ts",
    "test:unit": "vitest run --config vitest.unit.config.ts",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "test:watch": "vitest",
    "test:coverage": "vitest run --config vitest.unit.config.ts --coverage",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:wipe-import": "tsx scripts/wipe-import-data.ts",
    "db:seed": "nest build && node dist/cli/seed-football-data.js",
    "db:resume-import": "nest build && node dist/cli/resume-football-data.js",
    "db:recalculate-overall": "nest build && node dist/cli/recalculate-overall.js",
    "db:import-player": "nest build && node dist/cli/import-player.js",
    "db:audit-rosters": "nest build && node dist/cli/audit-thin-rosters.js",
    "db:backfill-images": "nest build && node dist/cli/backfill-player-images.js",
    "db:sync-missing-players": "nest build && node dist/cli/sync-missing-players.js",
    "db:backfill-metadata": "nest build && node dist/cli/backfill-player-metadata.js",
    "db:sync-coaches": "nest build && node dist/cli/sync-coaches.js",
    "db:sync-player-positions": "nest build && node dist/cli/sync-player-positions.js",
    "db:normalize-player-positions": "nest build && node dist/cli/normalize-player-positions.js",
    "db:studio": "prisma studio",
    "db:audit-nationalities": "tsx scripts/audit-nationality-translations.ts",
    "sportdb:smoke": "tsx scripts/sportdb-smoke.ts",
    "transfermarkt:smoke": "tsx scripts/transfermarkt-smoke.ts"
  },
  "dependencies": {
    "@draft-io/shared-types": "workspace:*",
    "@draft-io/shared-utils": "workspace:*",
    "@nestjs/common": "^11.1.2",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.2",
    "@nestjs/platform-express": "^11.1.2",
    "@nestjs/platform-socket.io": "^11.1.26",
    "@nestjs/websockets": "^11.1.26",
    "@prisma/client": "^6.9.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "ioredis": "^5.6.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "socket.io": "^4.8.3",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.5",
    "@nestjs/schematics": "^11.0.5",
    "@nestjs/testing": "^11.1.2",
    "@swc/core": "^1.11.29",
    "@types/express": "^5.0.2",
    "@types/supertest": "^6.0.3",
    "@types/uuid": "^10.0.0",
    "@vitest/coverage-v8": "^3.2.1",
    "prisma": "^6.9.0",
    "supertest": "^7.1.1",
    "tsx": "^4.20.6",
    "unplugin-swc": "^1.5.5",
    "vitest": "^3.2.1"
  }
}
